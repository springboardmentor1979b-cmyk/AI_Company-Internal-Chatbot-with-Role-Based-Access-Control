# NexusAI Configuration - Template
# Copy this file to .env and fill in your values
# WARNING: .env is included in .gitignore and should NOT be committed to version control

# ─── Backend Configuration ───────────────────────────────────────────────────

# Database
DATABASE_URL=nexusai.db

# JWT Secret Key - MUST be changed for production!
# Generate a new one: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_HOURS=8
JWT_REFRESH_EXPIRE_DAYS=7

# CORS Settings (comma-separated origins for production)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# RAG Data Folder
RAG_DATA_FOLDER=./backend/Fintech-data

# ─── Frontend Configuration ──────────────────────────────────────────────────

# Backend API URL
BACKEND_URL=http://localhost:8000

# ─── Optional: AI/ML Services ────────────────────────────────────────────────

# OpenAI API Key (optional, for advanced chat features)
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# ─── Server Settings ─────────────────────────────────────────────────────────

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Frontend Server
FRONTEND_PORT=8501

# ─── Logging ─────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO

# ─── Environment ─────────────────────────────────────────────────────────────

# Set to 'production', 'development', or 'testing'
ENVIRONMENT=development
